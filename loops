SET SERVEROUTPUT ON;  
DECLARE 
num1 NUMBER := 10; 
num2 NUMBER := 20; 
sum NUMBER; 
BEGIN 
sum := num1 + num2; 
DBMS_OUTPUT.PUT_LINE('The sum of ' || num1 || ' and ' || num2 || ' is: ' || sum); 
END; 
